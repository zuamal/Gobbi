{
  "name": "gobbi",
  "version": "0.1.0",
  "description": "Harness registry, benchmark, and installer CLI for coding agents",
  "type": "module",
  "bin": {
    "gobbi": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
