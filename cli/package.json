    "@types/node": "^20.14.0",
    "ajv": "^8.17.1",
    "tsup": "^8.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "zod-to-json-schema": "^3.24.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
