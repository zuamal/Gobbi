{
  "name": "gobbi",
  "version": "0.1.0",
  "description": "Harness registry, benchmark, and installer CLI for coding agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gobbi": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zuamal/gobbi.git"
  },
  "homepage": "https://github.com/zuamal/gobbi#readme",
  "bugs": {
    "url": "https://github.com/zuamal/gobbi/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "harness",
    "claude-code",
    "benchmark",
    "cli"
  ],
  "scripts": {
    "prepack": "cp ../README.md README.md && cp ../LICENSE LICENSE",
    "postpack": "rm -f README.md LICENSE",
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:schema": "tsx scripts/generate-schema.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ajv": "^8.17.1",
    "tsup": "^8.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "zod-to-json-schema": "^3.24.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
